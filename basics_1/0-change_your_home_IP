#!/usr/bin/env bash
# This script configures Ubuntu server to resolve localhost to 127.0.0.2 and facebook.com to 8.8.8.8

# Add or update localhost entry
sudo sed -i 's/^127\.0\.0\.1\s*localhost/127.0.0.2\tlocalhost/' /etc/hosts

# Add facebook.com entry
echo "8.8.8.8 facebook.com" | sudo tee -a /etc/hosts
